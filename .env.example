# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Local Development: postgres://postgres:postgres@localhost:5432/dev
# Hetzner VPS Local: postgres://<username>:<password>@localhost:5432/<db_name>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dev

# -----------------------------------------------------------------------------
# Security & Hashing
# -----------------------------------------------------------------------------
# Generate a long secure secret for signing session JWTs
JWT_SECRET=abrakadabragilligillichoo

# -----------------------------------------------------------------------------
# Resend Email Integration (For OTP Delivery)
# -----------------------------------------------------------------------------
# Get this from https://resend.com/api-keys
RESEND_API_KEY=re_123456789abcdef
# Must be a verified domain on Resend, or onboarding@resend.dev (for testing)
RESEND_FROM_EMAIL=Inquest <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# Google OAuth Configuration
# -----------------------------------------------------------------------------
# Get these credentials from Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# -----------------------------------------------------------------------------
# Server Routing & CORS (Used to resolve deployment bottlenecks)
# -----------------------------------------------------------------------------
# Local Dev Default Values:
CLIENT_URL=http://localhost:3000
BASE_URL=http://localhost:8000

# Submissions IP-based Rate Limiter Cache
# Local Dev Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379
